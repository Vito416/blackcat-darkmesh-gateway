{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blackcat.darkmesh/schemas/template/checkout.create-order.request.json",
  "title": "checkout.create-order request",
  "type": "object",
  "additionalProperties": true,
  "required": ["siteId", "items"],
  "properties": {
    "siteId": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "sku": { "type": "string" },
          "quantity": { "type": "number", "minimum": 0.000001 },
          "price": { "type": "number" }
        }
      }
    },
    "currency": {
      "type": "string",
      "minLength": 3
    },
    "customer": {
      "type": "object",
      "additionalProperties": true
    },
    "shipping": {
      "type": "object",
      "additionalProperties": true
    },
    "billing": {
      "type": "object",
      "additionalProperties": true
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
