{
  "name": "blackcat-darkmesh-gateway",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:integrity-fast": "bash scripts/ci/integrity-gate.sh",
    "test:integrity-gate": "npm run test:integrity-fast",
    "ops:compare-integrity": "node scripts/compare-integrity-state.js",
    "ops:compare-integrity-matrix": "node scripts/compare-integrity-matrix.js",
    "ops:attest-integrity": "node scripts/generate-integrity-attestation.js",
    "ops:export-integrity-evidence": "node scripts/export-integrity-evidence.js",
    "ops:validate-integrity-attestation": "node scripts/validate-integrity-attestation.js",
    "ops:build-attestation-exchange-pack": "node scripts/build-attestation-exchange-pack.js",
    "ops:index-evidence-bundles": "node scripts/index-evidence-bundles.js",
    "ops:build-drift-alert-summary": "node scripts/build-drift-alert-summary.js",
    "ops:build-release-evidence-pack": "node scripts/build-release-evidence-pack.js",
    "ops:check-evidence-bundle": "node scripts/check-evidence-bundle.js",
    "ops:latest-evidence-bundle": "node scripts/latest-evidence-bundle.js",
    "ops:dispatch-consistency-smoke": "node scripts/dispatch-consistency-smoke.js",
    "ops:suggest-ratelimit-overrides": "node scripts/suggest-ratelimit-overrides.js",
    "test:hardening": "vitest run tests/integrity-verifier.test.ts tests/resource-hardening.test.ts tests/budget-metrics.test.ts",
    "build": "tsc -p tsconfig.build.json",
    "smoke": "npm run build && node scripts/e2e-psp-smoke.js",
    "smoke:integrity-incident": "npm run build && node scripts/e2e-integrity-incident-smoke.js",
    "chaos": "npm run build && node scripts/e2e-psp-chaos.js"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.1"
  },
  "ts-node": {
    "experimentalSpecifierResolution": "node",
    "transpileOnly": true
  }
}
