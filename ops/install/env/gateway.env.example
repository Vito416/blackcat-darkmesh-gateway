# Gateway runtime (systemd EnvironmentFile)
# Copy to: /etc/blackcat/gateway.env

NODE_ENV=production
HOST=127.0.0.1
PORT=8080

# Resource profile (minimum production-like defaults)
GATEWAY_RESOURCE_PROFILE=vps_small

# Required upstreams (replace placeholders)
AO_MODULE_ID=change-me
AO_PROCESS_ID=change-me
WORKER_API_URL=https://worker.example.com
WORKER_AUTH_TOKEN=change-me

# Optional hardening / policy maps
# GATEWAY_TEMPLATE_TARGET_HOST_ALLOWLIST=gateway.example.com,worker.example.com
# GATEWAY_SITE_ID_BY_HOST_MAP={"gateway.example.com":"site-main"}
# GATEWAY_SITE_RESOLVE_MODE=hybrid
# GATEWAY_SITE_RESOLVE_AO_URL=https://ao.example.com
# GATEWAY_SITE_RESOLVE_TIMEOUT_MS=3000
# GATEWAY_SITE_RESOLVE_CACHE_TTL_MS=30000
# GATEWAY_SITE_RESOLVE_ALLOW_BODY_FALLBACK=0
# GATEWAY_TEMPLATE_WORKER_URL_MAP={"site-main":"https://worker.example.com/sign"}
# GATEWAY_TEMPLATE_WORKER_TOKEN_MAP={"site-main":"change-me"}
# GATEWAY_TEMPLATE_WORKER_SIGNATURE_REF_MAP={"site-main":"worker-ed25519"}
# GATEWAY_TEMPLATE_VARIANT_MAP={"site-main":{"variant":"signal","templateTxId":"tx","manifestTxId":"manifest"}}

# Optional consistency + integrity checks
# GATEWAY_INTEGRITY_STATE_TOKEN=change-me
# GATEWAY_INTEGRITY_CHECKPOINT_MODE=diskless
# GATEWAY_INTEGRITY_DISKLESS=1
