{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://darkmesh.fun/schemas/dm1/route-assertion.schema.json",
  "title": "Darkmesh route assertion response schema (site-inbox-worker)",
  "description": "Response shape returned by POST /route/assert and consumed by /route/assert/verify.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "assertion",
    "signature",
    "sigAlg",
    "signatureRef"
  ],
  "properties": {
    "ok": {
      "const": true
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "v",
        "iat",
        "exp",
        "challengeNonce",
        "challengeExp",
        "domain",
        "cfgTx",
        "hbHost"
      ],
      "properties": {
        "v": {
          "const": "dm-route-assert/1"
        },
        "iat": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4102444800
        },
        "exp": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4102444800
        },
        "challengeNonce": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]{8,256}$"
        },
        "challengeExp": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4102444800
        },
        "domain": {
          "type": "string",
          "pattern": "^(?=.{1,253}$)(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z0-9-]{2,63}$"
        },
        "cfgTx": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{32,128}$"
        },
        "hbHost": {
          "type": "string",
          "pattern": "^(?=.{1,253}$)(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z0-9-]{2,63}$"
        },
        "siteProcess": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "writeProcess": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "entryPath": {
          "type": "string",
          "pattern": "^/.*$",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    },
    "signature": {
      "type": "string",
      "pattern": "^[a-f0-9]{128}$",
      "description": "ed25519 signature hex"
    },
    "sigAlg": {
      "const": "ed25519"
    },
    "signatureRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    }
  },
  "x-runtimeRules": [
    "exp MUST be strictly greater than iat.",
    "challengeExp MUST be greater than or equal to exp.",
    "Verification endpoint MUST enforce skew and replay policy in addition to schema checks.",
    "assertion domain and hbHost MUST match expected values in verifier context when provided."
  ]
}
