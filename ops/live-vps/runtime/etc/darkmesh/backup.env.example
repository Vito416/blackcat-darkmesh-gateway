# Copy to /etc/darkmesh/backup.env and keep 0600.
# This file is sourced by /usr/local/sbin/darkmesh-backup.sh.
#
# Choose ONE provider profile below and fill values.

# Shared
RESTIC_HOST=darkmesh-vps
RESTIC_PASSWORD=

# -------------------------------------------------------------------
# Profile A: Backblaze B2 (recommended low-cost baseline)
# RESTIC_REPOSITORY format:
#   b2:<bucket-name>:<path-prefix>
# Example:
#   RESTIC_REPOSITORY=b2:darkmesh-backups:vps-65-109-99-102
# -------------------------------------------------------------------
# RESTIC_REPOSITORY=
# B2_ACCOUNT_ID=
# B2_ACCOUNT_KEY=

# -------------------------------------------------------------------
# Profile B: AWS S3
# RESTIC_REPOSITORY format:
#   s3:s3.amazonaws.com/<bucket-name>/<path-prefix>
# Example:
#   RESTIC_REPOSITORY=s3:s3.amazonaws.com/darkmesh-backups/vps-65-109-99-102
# -------------------------------------------------------------------
# RESTIC_REPOSITORY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-central-1

# Leave unused provider variables empty.
RESTIC_REPOSITORY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=
