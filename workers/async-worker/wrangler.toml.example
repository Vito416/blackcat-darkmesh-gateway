name = "blackcat-site-mailer"
main = "src/index.ts"
compatibility_date = "2025-01-01"
compatibility_flags = ["nodejs_compat"]

[vars]
MAIL_PROVIDER = ""
MAIL_FROM = "noreply@example.com"
# Strict auth token for internal trigger calls.
MAILER_AUTH_TOKEN = ""
JOBS_AUTH_TOKEN = ""
REFRESH_DOMAINS = "example.com"
HB_PROBE_ALLOWLIST = "hyperbeam.darkmesh.fun"
DNS_RESOLVER_URL = "https://dns.google/resolve"
AR_GATEWAY_URL = "https://arweave.net"
AR_GATEWAY_ALLOWLIST = "arweave.net"
SECRETS_WORKER_BASE_URL = "https://<secrets-worker-host>.workers.dev"
REFRESH_FETCH_TIMEOUT_MS = "2500"
CONFIG_MAX_BYTES = "262144"
DNS_RESPONSE_MAX_BYTES = "131072"
REFRESH_DOMAIN_COOLDOWN_SEC = "60"
STALE_GRACE_SEC = "300"

[[kv_namespaces]]
binding = "DOMAIN_MAP_KV"
id = "<replace-with-domain-map-kv-id>"
