# Worker (Cloudflare Workers / miniflare) example env
INBOX_TTL_DEFAULT=3600
INBOX_TTL_MAX=86400
REPLAY_TTL=600
INBOX_HMAC_SECRET=change-me-hmac
NOTIFY_HMAC_SECRET=change-me-hmac-notify
NOTIFY_HMAC_OPTIONAL=0
NOTIFY_WEBHOOK=https://webhook.example.com/notify
NOTIFY_RATE_MAX=50
NOTIFY_RATE_WINDOW=60
NOTIFY_DEDUPE_TTL=300
NOTIFY_BREAKER_THRESHOLD=5
NOTIFY_BREAKER_COOLDOWN=300
METRICS_BASIC_USER=prom
METRICS_BASIC_PASS=prompass
METRICS_BEARER_TOKEN=
WORKER_AUTH_TOKEN=change-me-forget
WORKER_READ_TOKEN=change-me-read
WORKER_FORGET_TOKEN=change-me-forget
WORKER_NOTIFY_TOKEN=change-me-notify
WORKER_SIGN_TOKEN=change-me-sign
WORKER_STRICT_TOKEN_SCOPES=1
TEST_IN_MEMORY_KV=0
REQUIRE_SECRETS=1
REQUIRE_METRICS_AUTH=1
AO_MODE=mainnet
AO_HB_URL=https://push.forward.computer
AO_HB_SCHEDULER=n_XZJhUnmldNFo4dhajoPZWhBXuJk-OcQr5JQ49c4Zo
AO_SITE_PROCESS_ID=replace-with-site-pid
WRITE_PROCESS_ID=replace-with-write-pid
GATEWAY_TEMPLATE_TOKEN=replace-with-bridge-template-token
GATEWAY_TEMPLATE_TOKEN_OPTIONAL=0
GATEWAY_READ_TIMEOUT_MS=30000
GATEWAY_WRITE_TIMEOUT_MS=45000
GATEWAY_WRITE_RETRIES=4
GATEWAY_WRITE_ACCEPT_EMPTY_RESULT=1
GATEWAY_WRITE_AUTO_SIGN=1
# Optional fail-closed /sign allowlist. Match by payload.siteId (or top-level siteId)
# and signatureRef. Each action maps to the allowed roles for that site/ref.
SIGN_POLICY_JSON={"sites":{"site-demo":{"CreateOrder":["admin"],"CreatePaymentIntent":["admin"]}},"signatureRefs":{"worker-ed25519":{"CreateOrder":["admin"],"CreatePaymentIntent":["admin"]}}}
AO_WALLET_JSON={"kty":"RSA","e":"AQAB","n":"..."}
# Optional: PKCS#8 DER private key encoded as base64 (preferred on runtimes with strict JWK import).
AO_WALLET_PKCS8_B64=
