# Production Worker (fail-closed defaults)

# Required secrets (must be set via wrangler secrets / vault). Runtime rejects placeholders.
FORGET_TOKEN=
WORKER_AUTH_TOKEN=
WORKER_READ_TOKEN=
WORKER_FORGET_TOKEN=
WORKER_NOTIFY_TOKEN=
WORKER_SIGN_TOKEN=
WORKER_STRICT_TOKEN_SCOPES=1
INBOX_HMAC_SECRET=
NOTIFY_HMAC_SECRET=

# Signature enforcement
INBOX_HMAC_OPTIONAL=0
NOTIFY_HMAC_OPTIONAL=0
AUTH_REQUIRE_SIGNATURE=1
AUTH_REQUIRE_NONCE=1
REQUIRE_SECRETS=1
REQUIRE_METRICS_AUTH=1
# Optional fail-closed /sign allowlist. Match by siteId (top-level or payload.siteId)
# and signatureRef.
SIGN_POLICY_REQUIRED=1
SIGN_POLICY_JSON={"sites":{"site-demo":{"CreateOrder":["admin"],"CreatePaymentIntent":["admin"]}},"signatureRefs":{"worker-ed25519":{"CreateOrder":["admin"],"CreatePaymentIntent":["admin"]}}}

# Metrics auth (choose bearer or basic)
METRICS_BEARER_TOKEN=
# METRICS_BASIC_USER=
# METRICS_BASIC_PASS=

# Rate limits / replay (tuned for prod SLA ~5 rps/IP; raise if needed)
# Retention policy: worker inbox is ephemeral only (hard-capped to <= 86400s in code).
# INBOX_TTL_DEFAULT=3600
# INBOX_TTL_MAX=86400
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=60
NOTIFY_RATE_MAX=20
NOTIFY_RATE_WINDOW=60
UNIQUE_SUBJECT_MAX_PER_IP=20
UNIQUE_SUBJECT_WINDOW=60
REPLAY_TTL=600
REPLAY_STRONG_MODE=1
SUBJECT_MAX_ENVELOPES=10
PAYLOAD_MAX_BYTES=65536
# REPLAY_LOCKS is a wrangler Durable Object binding, not an env var.

# Notification
NOTIFY_FROM=no-reply@example.com
# Optional destinations (one of):
# NOTIFY_WEBHOOK=https://example.com/hook
# NOTIFY_WEBHOOK_ALLOWLIST=example.com,api.your-psp.com  # REQUIRED allowlist; worker now fails closed if empty
# SENDGRID_KEY=SG.xxxxxx
HTTP_TIMEOUT_MS=8000
NOTIFY_RETRY_MAX=3
NOTIFY_RETRY_BACKOFF_MS=300
NOTIFY_BREAKER_THRESHOLD=5
NOTIFY_BREAKER_COOLDOWN=300
NOTIFY_DEDUPE_TTL=300

# Cron / scheduled
TEST_IN_MEMORY_KV=0
FORGET_MAX_KEYS=500

# Observability
METRICS_PROM_PATH=/tmp/worker-metrics.prom
# Set to 1 to disable metrics writes (testing only)
# METRICS_DISABLED=0

# Load test target (optional; only for k6/local tooling, never read in production code)
# WORKER_BASE_URL=https://<your-worker>.workers.dev

# AO bridge routing (optional explicit registry PID; falls back to AO_SITE_PROCESS_ID)
# AO_REGISTRY_PROCESS_ID=
