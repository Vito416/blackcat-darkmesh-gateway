# Gateway configuration (example, production-oriented)

# --------------------------------------------------------------------
# Core endpoints
# --------------------------------------------------------------------
AO_PUBLIC_API_URL=https://ao-read.example.com
AO_READ_URL=https://ao-read.example.com
WRITE_API_URL=https://ao-write.example.com
WORKER_API_URL=https://worker.example.com
WORKER_NOTIFY_URL=https://worker.example.com/notify
WORKER_AUTH_TOKEN=change-me
GATEWAY_FORGET_TOKEN=change-me-too

# --------------------------------------------------------------------
# Cache + memory budgets (WEDOS-friendly defaults)
# --------------------------------------------------------------------
GATEWAY_CACHE_TTL_MS=300000
GATEWAY_CACHE_MAX_ENTRY_BYTES=262144
GATEWAY_CACHE_MAX_ENTRIES=256
GATEWAY_CACHE_MAX_KEYS_PER_SUBJECT=64
GATEWAY_CACHE_ADMISSION_MODE=reject
GATEWAY_RL_WINDOW_MS=60000
GATEWAY_RL_MAX=120
GATEWAY_RL_MAX_BUCKETS=10000
# Optional per-prefix overrides for hot paths:
# format: prefix=max,prefix2=max2
GATEWAY_RL_MAX_OVERRIDES=inbox=80,webhook=240,template=120
GATEWAY_WEBHOOK_REPLAY_TTL_MS=600000
GATEWAY_WEBHOOK_REPLAY_MAX_KEYS=10000

# --------------------------------------------------------------------
# Integrity policy and snapshot controls
# --------------------------------------------------------------------
AO_INTEGRITY_URL=https://ao.example.com/integrity
AO_INTEGRITY_MIRROR_URLS=https://ao-mirror-1.example.com/integrity,https://ao-mirror-2.example.com/integrity
AO_INTEGRITY_MIRROR_STRICT=0
# Optional profile defaults for integrity fetch cadence (wedos_small|wedos_medium|diskless):
GATEWAY_RESOURCE_PROFILE=wedos_medium
AO_INTEGRITY_FETCH_TIMEOUT_MS=5000
AO_INTEGRITY_FETCH_RETRY_ATTEMPTS=3
AO_INTEGRITY_FETCH_RETRY_BACKOFF_MS=100
AO_INTEGRITY_FETCH_RETRY_JITTER_MS=25
GATEWAY_INTEGRITY_CACHE_TTL_MS=10000
GATEWAY_INTEGRITY_POLICY_PAUSED=0
GATEWAY_INTEGRITY_REQUIRE_VERIFIED_CACHE=1
GATEWAY_INTEGRITY_CHECKPOINT_PATH=./tmp/integrity-checkpoint.json
GATEWAY_INTEGRITY_CHECKPOINT_SECRET=change-me
GATEWAY_INTEGRITY_CHECKPOINT_MAX_AGE_SECONDS=86400
# Optional explicit memory-only mode:
# GATEWAY_INTEGRITY_DISKLESS=1
# GATEWAY_INTEGRITY_CHECKPOINT_MODE=diskless

# --------------------------------------------------------------------
# Integrity incident controls
# --------------------------------------------------------------------
GATEWAY_INTEGRITY_STATE_TOKEN=change-me
GATEWAY_INTEGRITY_INCIDENT_TOKEN=change-me
GATEWAY_INTEGRITY_INCIDENT_MAX_BODY_BYTES=16384
GATEWAY_INTEGRITY_INCIDENT_REQUIRE_SIGNATURE_REF=1
GATEWAY_INTEGRITY_INCIDENT_REF_HEADER=x-signature-ref
GATEWAY_INTEGRITY_INCIDENT_REPLAY_TTL_MS=1800000
GATEWAY_INTEGRITY_INCIDENT_REPLAY_CAP=256
GATEWAY_INTEGRITY_ROLE_ROOT_REFS=
GATEWAY_INTEGRITY_ROLE_UPGRADE_REFS=
GATEWAY_INTEGRITY_ROLE_EMERGENCY_REFS=
GATEWAY_INTEGRITY_ROLE_REPORTER_REFS=
GATEWAY_INTEGRITY_INCIDENT_NOTIFY_URL=
GATEWAY_INTEGRITY_INCIDENT_NOTIFY_TOKEN=
GATEWAY_INTEGRITY_INCIDENT_NOTIFY_HMAC=

# --------------------------------------------------------------------
# Template backend guardrails
# --------------------------------------------------------------------
GATEWAY_TEMPLATE_TOKEN=
GATEWAY_TEMPLATE_ALLOW_MUTATIONS=0
GATEWAY_TEMPLATE_HMAC_SECRET=
GATEWAY_TEMPLATE_MAX_BODY_BYTES=32768
GATEWAY_TEMPLATE_UPSTREAM_TIMEOUT_MS=7000
GATEWAY_TEMPLATE_TARGET_HOST_ALLOWLIST=
GATEWAY_SECURITY_HEADERS_ENABLE=1
# Optional strict CSP override (disabled by default):
# GATEWAY_SECURITY_HEADERS_CSP=default-src 'none'; frame-ancestors 'none'

# --------------------------------------------------------------------
# PSP and webhook hardening
# --------------------------------------------------------------------
GATEWAY_WEBHOOK_SHADOW_INVALID=0
GATEWAY_WEBHOOK_MAX_BODY_BYTES=262144
PAYPAL_WEBHOOK_SECRET=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_API_ALLOW_HOSTS=api-m.sandbox.paypal.com,api.paypal.com
PAYPAL_HTTP_TIMEOUT_MS=7000
PAYPAL_CERT_ALLOW_PREFIXES=https://api.paypal.com/
GW_CERT_PIN_SHA256=
GW_CERT_CACHE_TTL_MS=86400000

# --------------------------------------------------------------------
# Metrics auth
# --------------------------------------------------------------------
METRICS_BEARER_TOKEN=
METRICS_BASIC_USER=
METRICS_BASIC_PASS=
GATEWAY_REQUIRE_METRICS_AUTH=1
