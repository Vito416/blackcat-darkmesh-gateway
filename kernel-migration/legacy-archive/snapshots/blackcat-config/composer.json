{
  "name": "blackcatacademy/blackcat-config",
  "description": "Secure configuration hub/layer for the BlackCat ecosystem (profiles, hardening checks, compatible config sources).",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "ext-json": "*"
  },
  "autoload": {
    "psr-4": {
      "BlackCat\\Config\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BlackCat\\Config\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^1.11",
    "phpstan/phpstan-phpunit": "^1.4",
    "phpunit/phpunit": "^11.0 || ^12.0"
  },
  "scripts": {
    "test": "vendor/bin/phpunit --colors=always",
    "stan": "vendor/bin/phpstan analyse --configuration=phpstan.neon --memory-limit=512M"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "support": {
    "docs": "https://github.com/Vito416/blackcat-darkmesh-ao/blob/main/docs/BFNL-1.0.md",
    "source": "https://github.com/Vito416/blackcat-config"
  },
  "extra": {
    "blackcat-license": "BFNL-1.0",
    "blackcat-covered-system-notice": "https://github.com/Vito416/blackcat-darkmesh-ao/blob/main/docs/LICENSING_SYSTEM_NOTICE.md",
    "blackcat-founder-fee-policy": "https://github.com/Vito416/blackcat-darkmesh-ao/blob/main/docs/FEE_POLICY.md"
  }
}
