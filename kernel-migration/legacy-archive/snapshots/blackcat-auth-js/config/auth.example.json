{
  "profile": {
    "file": "../../blackcat-config/config/profiles.php",
    "name": "dev",
    "baseUrl": "https://localhost:9443",
    "defaultScopes": ["openid", "profile", "email"]
  },
  "auth": {
    "baseUrl": "${env:BLACKCAT_AUTH_BASE_URL|https://localhost:9443}",
    "clientId": "cli-dev",
    "clientSecret": "${env:BLACKCAT_AUTH_CLIENT_SECRET|dev-secret}",
    "defaultHeaders": {
      "X-BlackCat-Env": "dev"
    },
    "defaultScopes": ["openid", "profile", "email"]
  },
  "telemetry": {
    "filePath": "../var/log/auth-sdk.ndjson",
    "metricsFile": "../var/metrics/auth-sdk.prom",
    "observabilityBridge": "../../blackcat-observability/var/auth-sdk.ndjson"
  },
  "integrations": {
    "authService": "../../blackcat-auth/bin/auth",
    "database": "../../blackcat-database",
    "orchestrator": "../../blackcat-orchestrator/bin/orchestrator"
  },
  "security": {
    "requireHttps": true,
    "allowLocalhost": true,
    "allowedHosts": ["localhost"],
    "allowTestHosts": ["auth.dev.blackcat.local"],
    "minControls": ["encryption", "oidc"],
    "trustedModules": [
      "blackcat-auth",
      "blackcat-orchestrator",
      "blackcat-observability"
    ]
  },
  "checks": {
    "requireScopes": ["openid", "profile"],
    "requireIntegrations": ["authService", "database"],
    "requireControls": ["encryption"],
    "expectTelemetry": true
  },
  "mockUser": {
    "userId": "user-0",
    "email": "user@example.com",
    "roles": ["viewer"],
    "tokenTtl": 1800
  },
  "runtime": {
    "timeoutMs": 5000
  }
}
