#!/usr/bin/env node
const cli = require('../dist/cli.js');

if (!cli || typeof cli.runCli !== 'function') {
  console.error('[auth-sdk] CLI build missing, run `npm run build` first.');
  process.exit(1);
}

cli
  .runCli()
  .catch((error) => {
    console.error(`[auth-sdk] ${error.message || error}`);
    process.exit(1);
  });
