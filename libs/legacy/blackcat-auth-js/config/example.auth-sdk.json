{
  "profile": {
    "id": "dev-local",
    "baseUrl": "https://auth.dev.blackcat",
    "clientId": "installer",
    "clientSecret": "install-secret",
    "defaultScopes": ["openid", "profile", "offline_access"],
    "telemetrySampleRate": 1
  },
  "auth": {
    "baseUrl": "https://auth.dev.blackcat",
    "clientId": "installer",
    "clientSecret": "${env:BLACKCAT_AUTH_CLIENT_SECRET|install-secret}",
    "defaultScopes": ["openid", "profile", "offline_access"],
    "defaultHeaders": {
      "X-BlackCat-Env": "${env:BLACKCAT_ENV|dev}"
    }
  },
  "runtime": {
    "timeoutMs": 6000
  },
  "security": {
    "requireHttps": true,
    "allowedHosts": ["auth.dev.blackcat", "auth.staging.blackcat"],
    "minControls": ["jwt-signed", "jwe-encrypted", "integrity-metadata"],
    "allowTestHosts": ["localhost", "127.0.0.1"]
  },
  "integrations": {
    "auth": "blackcat-auth",
    "database": "blackcat-database",
    "observability": "blackcat-observability",
    "orchestrator": "blackcat-orchestrator",
    "crypto": "blackcat-crypto"
  },
  "checks": {
    "requireIntegrations": ["blackcat-auth", "blackcat-database", "blackcat-observability", "blackcat-orchestrator"],
    "requireScopes": ["openid", "profile"],
    "requireControls": ["jwt-signed", "integrity-metadata"],
    "expectTelemetry": true
  },
  "telemetry": {
    "filePath": "var/telemetry.ndjson",
    "metricsFile": "var/metrics.prom",
    "tailLimit": 50
  },
  "mockUser": {
    "userId": "user-123",
    "email": "dev@blackcat",
    "roles": ["admin"],
    "tokenTtl": 3600
  }
}
