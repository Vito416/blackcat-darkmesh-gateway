{
  "name": "blackcat/crypto",
  "description": "Centralized cryptography services for the BlackCat ecosystem (AEAD, HMAC, KMS wrapping, key rotations)",
  "keywords": [
    "blackcat",
    "cryptography",
    "security",
    "encryption",
    "aead",
    "xchacha20-poly1305",
    "hmac",
    "kms",
    "key-rotation",
    "libsodium"
  ],
  "homepage": "https://github.com/blackcatacademy/blackcat-crypto",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "ext-sodium": "*",
    "psr/log": "^3.0",
    "blackcatacademy/blackcat-config": "dev-dev"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^1.11"
  },
  "bin": [
    "bin/crypto"
  ],
  "autoload": {
    "psr-4": {
      "BlackCat\\Crypto\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BlackCat\\Crypto\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "stan": "vendor/bin/phpstan analyse src --memory-limit=512M"
  },
  "repositories": [
    {
      "type": "git",
      "url": "https://github.com/blackcatacademy/blackcat-config.git"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "support": {
    "docs": "https://github.com/Vito416/blackcat-darkmesh-ao/blob/main/docs/BFNL-1.0.md",
    "source": "https://github.com/Vito416/blackcat-crypto"
  },
  "extra": {
    "blackcat-license": "BFNL-1.0",
    "blackcat-covered-system-notice": "https://github.com/Vito416/blackcat-darkmesh-ao/blob/main/docs/LICENSING_SYSTEM_NOTICE.md",
    "blackcat-founder-fee-policy": "https://github.com/Vito416/blackcat-darkmesh-ao/blob/main/docs/FEE_POLICY.md"
  }
}
