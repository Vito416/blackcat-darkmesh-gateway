{
  "name": "blackcatacademy/blackcat-auth",
  "description": "Unified authentication & RBAC SDK for the BlackCat platform",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "psr/log": "^3.0",
    "ext-pdo": "*",
    "ext-sodium": "*",
    "blackcatacademy/blackcat-core": "dev-dev",
    "blackcatacademy/blackcat-config": "dev-dev",
    "blackcatacademy/blackcat-database": "dev-dev",
    "blackcatacademy/blackcat-sessions": "dev-dev",
    "blackcatacademy/blackcat-mailing": "dev-dev"
  },
  "repositories": [
    {
      "type": "git",
      "url": "https://github.com/blackcatacademy/blackcat-core"
    },
    {
      "type": "git",
      "url": "https://github.com/blackcatacademy/blackcat-config"
    },
    {
      "type": "git",
      "url": "https://github.com/blackcatacademy/blackcat-database"
    },
    {
      "type": "git",
      "url": "https://github.com/blackcatacademy/blackcat-database-crypto"
    },
    {
      "type": "git",
      "url": "https://github.com/blackcatacademy/blackcat-crypto"
    },
    {
      "type": "git",
      "url": "https://github.com/blackcatacademy/blackcat-sessions"
    },
    {
      "type": "git",
      "url": "https://github.com/blackcatacademy/blackcat-mailing"
    }
  ],
  "autoload": {
    "psr-4": {
      "BlackCat\\Auth\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BlackCat\\Auth\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/auth",
    "bin/auth-http"
  ],
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.11"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "support": {
    "docs": "https://github.com/Vito416/blackcat-darkmesh-ao/blob/main/docs/BFNL-1.0.md",
    "source": "https://github.com/Vito416/blackcat-auth"
  },
  "extra": {
    "blackcat-license": "BFNL-1.0",
    "blackcat-covered-system-notice": "https://github.com/Vito416/blackcat-darkmesh-ao/blob/main/docs/LICENSING_SYSTEM_NOTICE.md",
    "blackcat-founder-fee-policy": "https://github.com/Vito416/blackcat-darkmesh-ao/blob/main/docs/FEE_POLICY.md"
  }
}
