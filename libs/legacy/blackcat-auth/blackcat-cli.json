{
  "schema_version": 1,
  "component": {
    "id": "blackcat-auth",
    "name": "BlackCat Auth",
    "description": "Authentication & RBAC SDK and reference HTTP server for the BlackCat ecosystem.",
    "homepage": "https://github.com/blackcatacademy/blackcat-auth",
    "composer_package": "blackcatacademy/blackcat-auth"
  },
  "cli": {
    "entrypoints": [
      {
        "id": "auth",
        "command": "auth",
        "summary": "Auth CLI (reference tooling).",
        "type": "proxy",
        "proxy": {
          "runner": "php",
          "script": "bin/auth",
          "args": []
        }
      },
      {
        "id": "auth-http",
        "command": "auth-http",
        "summary": "Run the reference auth HTTP server.",
        "type": "proxy",
        "proxy": {
          "runner": "php",
          "script": "bin/auth-http",
          "args": []
        }
      }
    ]
  }
}

