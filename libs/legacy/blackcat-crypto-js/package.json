{
  "name": "@blackcat/crypto",
  "version": "0.1.0",
  "description": "BlackCat Crypto SDK for JavaScript (envelopes, HMAC slots, CLI workflows)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": "./dist/cli.js"
  },
  "bin": {
    "blackcat-crypto-js": "bin/crypto-js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "cli": "node dist/cli.js help",
    "security": "npm run build && node dist/cli.js checks:run --json",
    "verify": "npm run build && npm run test && npm run security"
  },
  "keywords": [
    "blackcat",
    "crypto",
    "aead",
    "kms"
  ],
  "author": "BlackCat",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "homepage": "https://github.com/Vito416/blackcat-darkmesh-ao/blob/main/docs/BFNL-1.0.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vito416/blackcat-crypto-js.git"
  },
  "bugs": {
    "url": "https://github.com/Vito416/blackcat-crypto-js/issues"
  },
  "blackcatLicense": "BFNL-1.0"
}
