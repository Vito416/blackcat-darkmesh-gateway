#!/usr/bin/env node
import('../dist/cli.js').then((mod) => {
  const runCli = mod.runCli ?? mod.default;
  if (typeof runCli !== 'function') {
    console.error('blackcat-crypto-js CLI is not built yet. Run `npm run build` first.');
    process.exit(1);
  }
  runCli().then(
    (code) => process.exit(code),
    (error) => {
      console.error(error);
      process.exit(1);
    }
  );
});
